<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.mycasa.app">

    <uses-permission android:name="android.permission.CAMERA"/>
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>
    <uses-feature android:name="android.hardware.camera" android:required="false"/>

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_mycasa_logo_foreground"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_mycasa_logo_foreground"
        android:supportsRtl="true"
        android:theme="@style/Theme.MyApplication">

        <!-- FileProvider -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.provider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths"/>
        </provider>

        <!-- Receiver של ההתראות -->
        <receiver android:name=".ReminderReceiver"/>

        <!-- Launcher -->
        <activity
            android:name=".StartActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <!-- Main screens -->
        <activity android:name=".Home"/>
        <activity android:name=".Finance"/>
        <activity android:name=".FinanceSetupActivity"/>
        <activity android:name=".ShoppingListActivity"/>
        <activity android:name=".TasksActivity"/>
        <activity android:name=".CalendarDayActivity"/>
        <activity android:name=".AddCalendarEventActivity"/>


        <activity android:name=".Add_Shopping"/>


        <!-- Group -->
        <activity android:name=".CreateGroupActivity"/>
        <activity android:name=".JoinGroupActivity"/>
        <activity android:name=".EditUserActivity"/>

        <!-- Other -->
        <activity android:name=".SettingsActivity"/>
        <activity android:name=".Add_Tasks"/>
        <activity android:name=".AddGoalActivity"/>
        <activity android:name=".ManageMembersActivity" />
        <activity android:name=".ChildPermissionsActivity" />
        <activity android:name=".Add_Transaction" />

    </application>

</manifest>