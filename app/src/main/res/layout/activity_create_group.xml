<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- כותרת -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="יצירת קבוצה"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <!-- ===== פרטי משתמש ===== -->

        <EditText
            android:id="@+id/etName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="שם"
            android:inputType="textPersonName"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/etPhone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="מספר טלפון"
            android:inputType="phone"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/etEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="אימייל"
            android:inputType="textEmailAddress"
            android:layout_marginBottom="20dp" />

        <!-- ===== פרטי קבוצה ===== -->

        <EditText
            android:id="@+id/etGroupCode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="קוד קבוצה (לפחות 6 תווים)"
            android:inputType="text"
            android:layout_marginBottom="20dp" />

        <!-- סוג קבוצה -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="סוג קבוצה"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <RadioGroup
            android:id="@+id/rgGroupType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp">

            <RadioButton
                android:id="@+id/rbFamily"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="משפחה" />

            <RadioButton
                android:id="@+id/rbPartners"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="שותפים" />

            <RadioButton
                android:id="@+id/rbCouple"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="זוג" />
        </RadioGroup>

        <!-- ===== תפקיד במשפחה (מוסתר בהתחלה) ===== -->

        <LinearLayout
            android:id="@+id/layoutFamilyRole"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="תפקיד במשפחה"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <RadioGroup
                android:id="@+id/rgFamilyRole"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/rbParent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="הורה" />

                <RadioButton
                    android:id="@+id/rbChild"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ילד" />
            </RadioGroup>
        </LinearLayout>

        <!-- כפתור יצירה -->
        <Button
            android:id="@+id/btnCreateGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="צור קבוצה" />

    </LinearLayout>

</ScrollView>
