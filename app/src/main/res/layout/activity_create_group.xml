<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:layoutDirection="rtl"
    android:background="@android:color/white">

    <!-- ===== Header ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:background="@drawable/bg_gradient_welcome">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_arrow_right"
            app:tint="@android:color/white"
            android:contentDescription="חזרה" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="יצירת קבוצה"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:layout_marginTop="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="צור קבוצה חדשה למשק הבית"
            android:textSize="16sp"
            android:textColor="#E0E7FF" />
    </LinearLayout>

    <!-- ===== Form ===== -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Name -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/LabelStyle"
                android:text="שם" />

            <EditText
                android:id="@+id/etName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/InputStyle"
                android:hint="הזן את שמך"
                android:drawableEnd="@drawable/ic_user" />

            <!-- Phone -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/LabelStyle"
                android:text="קוד קבוצה" />

            <EditText
                android:id="@+id/etGroupCode"
                style="@style/InputStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:drawableEnd="@drawable/ic_key"
                android:hint="הזן קוד ייחודי" />

            <Button
                android:id="@+id/btnSuggestCode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔄 הצע קוד אחר"
                android:layout_marginTop="8dp"
                android:backgroundTint="@color/indigo_600"
                android:textColor="@android:color/white"/>


            <!-- Phone -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/LabelStyle"
                android:text="מספר טלפון" />

            <EditText
                android:id="@+id/etPhone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/InputStyle"
                android:inputType="phone"
                android:hint="050-1234567"
                android:drawableEnd="@drawable/ic_phone" />

            <!-- Email -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/LabelStyle"
                android:text="אימייל" />

            <!-- Group Code -->
            <EditText
                android:id="@+id/etEmail"
                style="@style/InputStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:drawableEnd="@drawable/ic_mail"
                android:hint="example@email.com"
                android:inputType="textEmailAddress" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/LabelStyle"
                android:text="קוד קבוצה (לפחות 6 תווים)" />

            <!-- Group Type -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/LabelStyle"
                android:text="סוג קבוצה"
                android:layout_marginTop="12dp" />

            <RadioGroup
                android:id="@+id/rgGroupType"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/rbFamily"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/RadioCardStyle"
                    android:text="משפחה" />

                <RadioButton
                    android:id="@+id/rbPartners"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/RadioCardStyle"
                    android:text="שותפים" />

                <RadioButton
                    android:id="@+id/rbCouple"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/RadioCardStyle"
                    android:text="זוג" />
            </RadioGroup>

            <!-- ===== Family Extra Fields ===== -->
            <LinearLayout
                android:id="@+id/layoutFamilyRole"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/LabelStyle"
                    android:text="שם משפחה" />

                <EditText
                    android:id="@+id/etFamilyName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/InputStyle"
                    android:hint="הזן שם משפחה" />


                <RadioGroup
                    android:id="@+id/rgFamilyRole"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">

                    <RadioButton
                        android:id="@+id/rbParent"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        style="@style/RadioCardStyle"
                        android:text="הורה" />

                    <RadioButton
                        android:id="@+id/rbChild"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        style="@style/RadioCardStyle"
                        android:text="ילד" />
                </RadioGroup>

            </LinearLayout>

            <!-- Submit -->
            <Button
                android:id="@+id/btnCreateGroup"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="צור קבוצה"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:background="@drawable/bg_gradient_welcome"
                android:backgroundTint="@null"
                app:backgroundTint="@null"
                android:layout_marginTop="32dp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
