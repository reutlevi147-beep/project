<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layoutDirection="rtl"
    android:background="#F5F5F5">

    <!-- HEADER -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="48dp"
        android:paddingBottom="24dp"
        android:paddingHorizontal="20dp"
        android:background="@drawable/bg_tasks_header">

        <!-- שורת אייקונים -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@android:color/transparent"
                android:src="@drawable/ic_arrow_right"
                app:tint="@android:color/white" />

            <ImageButton
                android:id="@+id/btnTasks"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@android:color/transparent"
                android:src="@drawable/ic_list"
                app:tint="@android:color/white" />
        </LinearLayout>

        <!-- כותרת -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="המשימות שלי"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:layout_marginTop="16dp" />

        <!-- סטטיסטיקה -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="16dp"
            android:weightSum="2">

            <include
                android:id="@+id/statActive"
                layout="@layout/item_task_stat"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"/>

            <include
                android:id="@+id/statCompleted"
                layout="@layout/item_task_stat"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"/>

        </LinearLayout>
    </LinearLayout>

    <!-- CONTENT -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="260dp"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- קטגוריות -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/categoriesContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnAll"
                        style="@style/CategoryButtonSelected"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="הכל"
                        android:layout_marginEnd="8dp"/>

                    <Button
                        android:id="@+id/btnFamily"
                        style="@style/CategoryButton"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="משפחה"
                        android:layout_marginEnd="8dp"/>

                    <Button
                        android:id="@+id/btnHome"
                        style="@style/CategoryButton"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="בית"
                        android:layout_marginEnd="8dp"/>

                    <Button
                        android:id="@+id/btnWork"
                        style="@style/CategoryButton"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="עבודה"
                        android:layout_marginEnd="8dp"/>

                    <Button
                        android:id="@+id/btnShopping"
                        style="@style/CategoryButton"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="קניות"
                        android:layout_marginEnd="8dp"/>

                    <Button
                        android:id="@+id/btnPersonal"
                        style="@style/CategoryButton"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="אישי"
                        android:layout_marginEnd="8dp"/>

                    <Button
                        android:id="@+id/btnHealth"
                        style="@style/CategoryButton"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="בריאות"
                        android:layout_marginEnd="8dp"/>

                    <Button
                        android:id="@+id/btnOther"
                        style="@style/CategoryButton"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="אחר"
                        android:layout_marginEnd="8dp"/>

                </LinearLayout>

            </HorizontalScrollView>

            <!-- כותרת -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="משימות פעילות"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#111"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="12dp"/>


            <!-- רשימת משימות -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerTasks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                tools:listitem="@layout/task_item"/>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddTask"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="24dp"
        android:src="@drawable/ic_plus"
        app:backgroundTint="@color/indigo"
        app:tint="@android:color/white"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
