<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FDF1F8"
    tools:context=".Display_Calender_Tasks">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingBottom="20dp"
        android:gravity="center_horizontal">

        <!-- ===== רווח עליון ===== -->
        <View
            android:layout_width="match_parent"
            android:layout_height="40dp" />

        <!-- ====================== משימות הבית ====================== -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp">

            <ImageButton
                android:id="@+id/Plos"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:background="@drawable/round_white_button"
                android:src="@drawable/plos"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"/>

            <TextView
                android:id="@+id/titleTasks"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="משימות הבית"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:layout_centerHorizontal="true"
                android:gravity="center"/>
        </RelativeLayout>

        <!-- ====================== רשימת משימות (RecyclerView) ====================== -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerTasks"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:overScrollMode="never"
            android:nestedScrollingEnabled="false"
            android:layout_marginBottom="25dp"
            tools:listitem="@layout/task_item" />

        <!-- ====================== כפתור הצגת כל המשימות ====================== -->
        <TextView
            android:id="@+id/showMoreTasks"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="הצג את כל המשימות"
            android:textColor="#2D8BBA"
            android:textSize="18sp"
            android:padding="10dp"
            android:layout_marginBottom="25dp"
            android:gravity="center"
            android:visibility="gone"
            android:layout_gravity="center" />

        <!-- ====================== יומן ====================== -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="5dp">

            <ImageButton
                android:id="@+id/plos"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:background="@drawable/round_white_button"
                android:src="@drawable/plos"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"/>

            <TextView
                android:id="@+id/titleCalendar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="יומן"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:layout_centerHorizontal="true"
                android:gravity="center"/>
        </RelativeLayout>

        <!-- תת כותרת -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="אירועים - חוגים - פגישות"
            android:textColor="#000000"
            android:textSize="18sp"
            android:gravity="center"
            android:layout_marginBottom="10dp" />

        <!-- בלוקים ביומן -->
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:layout_marginBottom="10dp"
            android:src="@drawable/task_block"/>

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:layout_marginBottom="10dp"
            android:src="@drawable/task_block"/>

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:layout_marginBottom="30dp"
            android:src="@drawable/task_block"/>

        <!-- פוטר -->
        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/fragment_footer"
            android:name="com.example.myapplication.footerFragment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

    </LinearLayout>

</ScrollView>
