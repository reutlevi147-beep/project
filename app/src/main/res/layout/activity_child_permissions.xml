<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F6F8">

    <!-- ===== HEADER ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:orientation="vertical"
        android:gravity="center_vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="48dp"
        android:background="#5C5F66">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ניהול הרשאות"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"/>

    </LinearLayout>

    <!-- ===== CONTENT ===== -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <include
                android:id="@+id/sectionFinance"
                layout="@layout/item_permission_section"/>

            <include
                android:id="@+id/sectionShopping"
                layout="@layout/item_permission_section"/>

            <include
                android:id="@+id/sectionTasks"
                layout="@layout/item_permission_section"/>

            <include
                android:id="@+id/sectionCalendar"
                layout="@layout/item_permission_section"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSavePermissions"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="24dp"
                android:text="שמור הרשאות"
                android:textColor="@android:color/white"
                android:backgroundTint="#5B5CE6"/>

        </LinearLayout>

    </ScrollView>

</LinearLayout>