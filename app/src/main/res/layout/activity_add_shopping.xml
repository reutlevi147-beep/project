<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F9FAFB">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- ===== HEADER ===== -->

        <!-- ===== הצעות ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="195dp"
            android:background="@drawable/bg_gradient_teal"
            android:orientation="vertical"
            android:padding="20dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_arrow_right"
                app:tint="@android:color/white" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="הוסף מוצר"
                android:textColor="@android:color/white"
                android:textSize="26sp"
                android:textStyle="bold" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvSuggestedTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="רשימה מוצעת"
            android:textStyle="bold"
            android:textSize="14sp"
            android:textColor="#374151"
            android:layout_margin="12dp"
            android:visibility="gone"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerSuggestions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="12dp"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- שם מוצר -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <EditText
                    android:id="@+id/etItemName"
                    android:layout_width="369dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="שם המוצר" />


                <ImageButton
                    android:id="@+id/btnConfirmName"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_check"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="אישור שם מוצר"/>

            </LinearLayout>



            <!-- כמות -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="8dp"
                android:padding="14dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_user_card">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="כמות"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:textColor="#111827"/>

                <ImageButton
                    android:id="@+id/btnMinus"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_minus"
                    android:background="@drawable/bg_circle_light"/>

                <TextView
                    android:id="@+id/tvQuantity"
                    android:layout_width="40dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="1"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#111827"/>

                <ImageButton
                    android:id="@+id/btnPlus"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_plus"
                    android:background="@drawable/bg_circle_light"/>
            </LinearLayout>




            <!-- קטגוריה -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="קטגוריה *"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_marginStart="16dp"
                android:layout_marginBottom="8dp" />

            <!-- ⭐ כאן הקסם: RecyclerView בלי ScrollView -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerCategories"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="16dp"/>

            <!-- ===== שדות נוספים עם ScrollView ===== -->
            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:paddingBottom="96dp"
                android:clipToPadding="false">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:orientation="vertical">



                    <!-- דחוף -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="14dp"
                        android:layout_marginTop="20dp"
                        android:background="@drawable/bg_user_card">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="מוצר דחוף"
                            android:textStyle="bold"
                            android:textColor="#111827"/>

                        <Switch
                            android:id="@+id/switchUrgent"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                    </LinearLayout>

                    <!-- הערות -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="הערות"
                        android:textStyle="bold"
                        android:textColor="#111827"
                        android:layout_marginTop="20dp"/>

                    <EditText
                        android:id="@+id/etNotes"
                        android:layout_width="match_parent"
                        android:layout_height="100dp"
                        android:gravity="top"
                        android:hint="הערות נוספות…"
                        android:inputType="textMultiLine"
                        android:background="@drawable/bg_input_outline"
                        android:padding="14dp"/>
                </LinearLayout>
            </ScrollView>
        </LinearLayout>

        <!-- ===== ACTIONS ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:background="@android:color/white">

            <Button
                android:id="@+id/btnCancel"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="ביטול"
                android:background="@drawable/bg_button_neutral"/>

            <Button
                android:id="@+id/btnSave"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:text="הוסף לרשימה"
                android:textColor="@android:color/white"
                android:background="@drawable/bg_button_teal"/>
        </LinearLayout>

    </LinearLayout>
</FrameLayout>
