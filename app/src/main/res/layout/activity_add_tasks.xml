<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Add_Tasks">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="643dp">

        <!-- תמונת רקע -->
        <ImageView
            android:layout_width="351dp"
            android:layout_height="557dp"
            android:layout_marginLeft="40dp"
            android:layout_marginTop="159dp"
            android:scaleType="centerCrop"
            android:src="@drawable/c2" />

        <ImageButton
            android:id="@+id/Return"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="5dp"
            android:layout_marginTop="10dp"
            android:background="@null"
            android:clickable="true"
            android:focusable="true"
            android:src="@drawable/return1" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="120dp"
            android:layout_marginTop="100dp"
            android:shadowColor="#80000000"
            android:shadowDx="2"
            android:shadowDy="2"
            android:shadowRadius="4"
            android:text="הכנסת משימה"
            android:textColor="#000000"
            android:textSize="30sp" />

        <!-- שדה המשימה -->
        <EditText
            android:id="@+id/task"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="60dp"
            android:layout_marginTop="230dp"
            android:background="@android:color/transparent"
            android:hint="המשימה"
            android:textColor="#000000"
            android:textSize="30sp" />

        <!-- ✅ בחירת מבצעים – צ׳קבוקסים קבועים -->
        <LinearLayout
            android:id="@+id/users_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="60dp"
            android:layout_marginTop="360dp"
            android:orientation="vertical">

            <CheckBox
                android:id="@+id/check_all"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="כולם"
                android:textSize="20sp" />

            <CheckBox
                android:id="@+id/check_user1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="דנה"
                android:textSize="18sp" />

            <CheckBox
                android:id="@+id/check_user2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="רון"
                android:textSize="18sp" />

            <CheckBox
                android:id="@+id/check_user3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="יעל"
                android:textSize="18sp" />
        </LinearLayout>

        <!-- כפתור הוספת משימה -->
        <Button
            android:id="@+id/add_to_task"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="100dp"
            android:layout_marginTop="540dp"
            android:backgroundTint="#2d8bba"
            android:text="הוספת משימה"
            android:textColor="#000000"
            android:textSize="30sp" />

    </FrameLayout>

    <!-- Footer -->
    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/fragment_footer"
        android:name="com.example.myapplication.footerFragment"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom" />

</LinearLayout>
