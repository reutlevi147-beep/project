<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Home">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- כותרת- ניהול משק בית -->
        <ImageView
            android:id="@+id/HTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="100dp"
            android:layout_marginTop="40dp"
            android:background="@null"
            android:clickable="true"
            android:focusable="true"
            android:src="@drawable/h_title" />

        <!-- פעמון -->

        <ImageButton
            android:id="@+id/HBell"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="30dp"
            android:layout_marginTop="10dp"
            android:background="@null"
            android:clickable="true"
            android:focusable="true"
            android:src="@drawable/bell" />
    </LinearLayout>

    <!-- כלכלת בית -->

    <ImageButton
        android:id="@+id/H_Economy"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="50dp"
        android:layout_marginTop="20dp"
        android:background="@null"
        android:clickable="true"
        android:focusable="true"
        android:src="@drawable/h_economy" />

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="3"
        android:orientation="horizontal"
        android:rowCount="2">

        <!-- קניות -->
        <!-- קניות -->
        <LinearLayout
            android:id="@+id/shoppingBox"
            android:layout_width="150dp"
            android:layout_height="151dp"
            android:layout_row="0"
            android:layout_column="0"
            android:orientation="vertical"
            android:padding="10dp"
            android:background="@drawable/box_background"
            android:layout_marginLeft="50dp"
            android:layout_marginTop="10dp"
            android:clickable="true"
            android:focusable="true">

            <!-- כותרת -->
            <TextView
                android:id="@+id/shoppingTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="קניות"
                android:textSize="16sp"
                android:textColor="#000000"
                android:layout_gravity="center_horizontal"
                android:paddingBottom="4dp"/>

            <TextView
                android:id="@+id/noItemsText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="אין פריטים בעגלה"
                android:textSize="14sp"
                android:textColor="@android:color/darker_gray"
                android:visibility="gone"
                android:layout_gravity="center_horizontal"
                android:paddingTop="6dp"/>


            <!-- רשימת 4 פריטים אחרונים -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/homeShoppingPreview"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"/>

            <!-- אייקון עגלה -->
            <ImageView
                android:id="@+id/shoppingIcon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_cart"
                android:layout_gravity="end"/>

        </LinearLayout>


        <!-- משימות בית -->
        <ImageButton
            android:id="@+id/HTasks"
            android:layout_width="163dp"
            android:layout_height="wrap_content"
            android:layout_row="0"
            android:layout_column="1"
            android:layout_marginTop="8dp"
            android:layout_marginRight="-5dp"
            android:background="@null"
            android:clickable="true"
            android:focusable="true"
            android:src="@drawable/h_tasks" />

        <!-- יומן -->
        <ImageButton
            android:id="@+id/HCalender"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_row="1"
            android:layout_column="0"
            android:layout_marginLeft="50dp"
            android:layout_marginTop="5dp"
            android:background="@null"
            android:clickable="true"
            android:focusable="true"
            android:src="@drawable/h_calender" />

        <!-- הגדרות -->
        <LinearLayout
            android:id="@+id/settingsBox"
            android:layout_width="150dp"
            android:layout_height="151dp"
            android:layout_row="1"
            android:layout_column="1"
            android:orientation="vertical"
            android:padding="10dp"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/box_background"
            android:layout_marginLeft="10dp"
            android:layout_marginBottom="5dp">

            <!-- כותרת -->
            <TextView
                android:id="@+id/settingsTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="הגדרות"
                android:textSize="16sp"
                android:textColor="#000000"
                android:layout_gravity="center_horizontal"
                android:paddingBottom="4dp"/>

            <!-- רשימת משתמשים -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/settingsUsersList"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"/>

            <!-- אייקון גלגל שיניים -->
            <ImageView
                android:id="@+id/settingsIcon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_settings"
                android:layout_gravity="end"/>

        </LinearLayout>

    </GridLayout>

    <!-- שורת משימות (Footer Fragment) -->
    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/fragment_footer"
        android:name="com.example.myapplication.footerFragment"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom" />

</LinearLayout>