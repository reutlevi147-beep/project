<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Home">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- כותרת- ניהול משק בית -->
        <ImageView
            android:id="@+id/HTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="100dp"
            android:layout_marginTop="40dp"
            android:background="@null"
            android:clickable="true"
            android:focusable="true"
            android:src="@drawable/h_title" />

        <!-- פעמון -->
        <ImageButton
            android:id="@+id/HBell"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="62dp"
            android:layout_marginTop="10dp"
            android:background="@null"
            android:clickable="true"
            android:focusable="true"
            android:src="@drawable/bell" />
    </LinearLayout>

    <!-- כלכלת בית -->
    <ImageButton
        android:id="@+id/H_Economy"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="50dp"
        android:layout_marginTop="20dp"
        android:background="@null"
        android:clickable="true"
        android:focusable="true"
        android:src="@drawable/h_economy" />

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="3"
        android:orientation="horizontal"
        android:padding="0dp"
        android:rowCount="2">

        <!-- קניות -->
        <ImageButton
            android:id="@+id/HShopping"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_row="0"
            android:layout_column="0"
            android:layout_marginLeft="50dp"
            android:layout_marginTop="10dp"
            android:background="@null"
            android:clickable="true"
            android:focusable="true"
            android:src="@drawable/h_shopping" />

        <!-- משימות בית -->
        <ImageButton
            android:id="@+id/HTasks"
            android:layout_width="163dp"
            android:layout_height="wrap_content"
            android:layout_row="0"
            android:layout_column="1"
            android:layout_marginTop="8dp"
            android:layout_marginRight="-5dp"
            android:background="@null"
            android:clickable="true"
            android:focusable="true"
            android:src="@drawable/h_tasks" />

        <!-- יומן -->
        <ImageButton
            android:id="@+id/HCalender"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_row="1"
            android:layout_column="0"
            android:layout_marginLeft="50dp"
            android:layout_marginTop="5dp"
            android:background="@null"
            android:clickable="true"
            android:focusable="true"
            android:src="@drawable/h_calender" />

        <!-- הגדרות -->
        <ImageButton
            android:id="@+id/HSetting"
            android:layout_width="wrap_content"
            android:layout_height="151dp"
            android:layout_row="1"
            android:layout_column="1"
            android:layout_marginLeft="10dp"
            android:layout_marginBottom="5dp"
            android:background="@null"
            android:clickable="true"
            android:focusable="true"
            android:src="@drawable/h_setting" />
    </GridLayout>

    <!-- שורת משימות -->
    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="5"
        android:orientation="horizontal"
        android:padding="0dp"
        android:rowCount="1">

        <ImageButton
            android:id="@+id/M1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="16dp"
            android:layout_marginTop="39dp"
            android:background="@null"
            android:clickable="true"
            android:focusable="true"
            android:src="@drawable/m1" />

        <ImageButton
            android:id="@+id/M2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="1dp"
            android:layout_marginTop="43dp"
            android:background="@null"
            android:clickable="true"
            android:focusable="true"
            android:src="@drawable/m2" />

        <ImageButton
            android:id="@+id/M3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="7dp"
            android:layout_marginTop="39dp"
            android:background="@null"
            android:clickable="true"
            android:focusable="true"
            android:src="@drawable/m3" />

        <ImageButton
            android:id="@+id/M4"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="8dp"
            android:layout_marginTop="52dp"
            android:background="@null"
            android:clickable="true"
            android:focusable="true"
            android:src="@drawable/m4" />

        <ImageButton
            android:id="@+id/M5"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="1dp"
            android:layout_marginTop="52dp"
            android:background="@null"
            android:clickable="true"
            android:focusable="true"
            android:src="@drawable/m5" />
    </GridLayout>

</LinearLayout>
