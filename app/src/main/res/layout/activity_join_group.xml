<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- כותרת -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="הצטרפות לקבוצה"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <!-- פרטי משתמש -->
        <EditText
            android:id="@+id/etName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="שם"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/etPhone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="מספר טלפון"
            android:inputType="phone"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/etEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="אימייל"
            android:inputType="textEmailAddress"
            android:layout_marginBottom="20dp" />

        <!-- קוד קבוצה -->
        <EditText
            android:id="@+id/etGroupCode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="קוד קבוצה"
            android:layout_marginBottom="24dp" />

        <!-- ===== תפקיד במשפחה (מוסתר כברירת מחדל) ===== -->
        <LinearLayout
            android:id="@+id/layoutFamilyRole"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="תפקיד במשפחה"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <RadioGroup
                android:id="@+id/rgFamilyRole"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/rbParent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="הורה" />

                <RadioButton
                    android:id="@+id/rbChild"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ילד" />
            </RadioGroup>
        </LinearLayout>

        <!-- כפתור -->
        <Button
            android:id="@+id/btnJoinGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="הצטרף לקבוצה" />



    </LinearLayout>

</ScrollView>
