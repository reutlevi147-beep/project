<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:layoutDirection="rtl"
    android:background="@android:color/white">

    <!-- ===== Header ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:background="@drawable/bg_gradient_join">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_arrow_right"
            app:tint="@android:color/white"
            android:contentDescription="חזרה" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="הצטרפות לקבוצה"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:layout_marginTop="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="הצטרף לקבוצת משק בית קיימת"
            android:textSize="16sp"
            android:textColor="#CCFBF1" />
    </LinearLayout>

    <!-- ===== Form ===== -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Name -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/LabelStyle"
                android:text="שם" />

            <EditText
                android:id="@+id/etName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/InputStyle"
                android:hint="הזן את שמך"
                android:drawableEnd="@drawable/ic_user" />

            <!-- Phone -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/LabelStyle"
                android:text="מספר טלפון" />

            <EditText
                android:id="@+id/etPhone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/InputStyle"
                android:inputType="phone"
                android:hint="050-1234567"
                android:drawableEnd="@drawable/ic_phone" />

            <!-- Email -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/LabelStyle"
                android:text="אימייל" />

            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/InputStyle"
                android:inputType="textEmailAddress"
                android:hint="example@email.com"
                android:drawableEnd="@drawable/ic_mail" />

            <!-- Group Code -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/LabelStyle"
                android:text="קוד קבוצה" />

            <EditText
                android:id="@+id/etGroupCode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/InputStyle"
                android:hint="הזן קוד קבוצה"
                android:drawableEnd="@drawable/ic_key" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="בקש את קוד הקבוצה ממנהל הקבוצה"
                android:textSize="13sp"
                android:textColor="#6B7280"
                android:layout_marginTop="4dp" />
            <!-- ===== Family Role (hidden initially) ===== -->
            <LinearLayout
                android:id="@+id/layoutFamilyRole"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginTop="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/LabelStyle"
                    android:text="אני" />

                <RadioGroup
                    android:id="@+id/rgFamilyRole"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">

                    <RadioButton
                        android:id="@+id/rbParent"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        style="@style/RadioCardStyle"
                        android:text="הורה" />

                    <RadioButton
                        android:id="@+id/rbChild"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        style="@style/RadioCardStyle"
                        android:text="ילד" />
                </RadioGroup>
            </LinearLayout>



            <!-- Submit -->
            <Button
                android:id="@+id/btnJoinGroup"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="הצטרפות לקבוצה"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:background="@drawable/bg_button_join_solid"
                android:backgroundTint="@null"
                app:backgroundTint="@null"
                android:layout_marginTop="24dp" />


            <!-- Info box -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_info_join">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💡 לאחר ההצטרפות, תוכל לראות ולנהל את משימות הקבוצה"
                    android:textSize="14sp"
                    android:textColor="#065F46" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
