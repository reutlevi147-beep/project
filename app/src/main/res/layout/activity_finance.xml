<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F9FAFB">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:id="@+id/mainContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">



            <!-- ===== HEADER ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp"
                android:background="@drawable/bg_gradient_indigo"
                android:orientation="vertical">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                <ImageButton
                    android:id="@+id/btnBack"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_arrow_right"
                    app:tint="@android:color/white" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_weight="1" />
                <ImageButton
                    android:id="@+id/btnFinanceSettings"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_settings"
                    android:contentDescription="הגדרות כלכלה"
                    app:tint="@android:color/white" />
                </LinearLayout>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="כלכלה"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white"
                    android:layout_marginTop="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="מעקב אחר הכנסות והוצאות"
                    android:textColor="@android:color/white"
                    android:alpha="0.85" />
            </LinearLayout>

            <!-- ===== Month Selector ===== -->
            <LinearLayout
                android:id="@+id/layoutMonthSelector"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:padding="12dp">

                <ImageButton
                    android:id="@+id/btnPrevMonth"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_chevron_left"
                    android:contentDescription="חודש קודם" />

                <TextView
                    android:id="@+id/tvSelectedMonth"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    android:text="מרץ 2026"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#111827" />

                <ImageButton
                    android:id="@+id/btnNextMonth"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_chevron_right"
                    android:contentDescription="חודש הבא" />

            </LinearLayout>


            <!-- ===== BODY ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <!-- ===== SUMMARY CARDS ===== -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/bg_card_teal"
                        android:padding="16dp"
                        android:orientation="vertical">


                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="הכנסות החודש"
                            android:textColor="@android:color/white"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tvIncomeMonth"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₪8,000"
                            android:textColor="@android:color/white"
                            android:textSize="22sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <Space
                        android:layout_width="12dp"
                        android:layout_height="1dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/bg_card_slate"
                        android:padding="16dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="הוצאות החודש"
                            android:textColor="@android:color/white"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tvExpenseMonth"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₪4,200"
                            android:textColor="@android:color/white"
                            android:textSize="22sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <!-- ===== BALANCE CARD ===== -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:padding="20dp"
                    android:background="@drawable/bg_card_indigo"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="יתרה חודשית"
                        android:textColor="@android:color/white"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tvBalanceMonth"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₪3,800"
                        android:textColor="@android:color/white"
                        android:textSize="32sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="יעד חיסכון חודשי"
                        android:textColor="@android:color/white"
                        android:layout_marginTop="12dp" />

                    <ProgressBar
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:max="100"
                        android:progress="60"
                        android:progressDrawable="@drawable/progress_white"
                        android:background="@android:color/transparent" />
                </LinearLayout>

                <!-- ===== SMART GOAL ALERTS ===== -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardGoalAlerts"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="8dp"
                    android:visibility="gone"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#FFF1F2">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <!-- Header -->
                        <LinearLayout
                            android:id="@+id/headerGoalAlertsTop"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="⚠️ התראות למטרות"
                                android:textStyle="bold"
                                android:textSize="16sp"
                                android:textColor="#7F1D1D"/>

                            <ImageView
                                android:id="@+id/imgGoalAlertsArrowTop"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_chevron_up"
                                app:tint="#7F1D1D"/>
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/layoutGoalAlertsContentTop"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="12dp"/>

                            <androidx.recyclerview.widget.RecyclerView
                                android:id="@+id/rvGoalAlerts"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:nestedScrollingEnabled="false"/>
                        </LinearLayout>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>



                <!-- ===== PENDING APPROVALS (Yellow Block) ===== -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardPending"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="16dp"
                    android:visibility="gone"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#FFF9E6">

                <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <!-- Header -->
                        <LinearLayout
                            android:id="@+id/headerPending"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:id="@+id/tvPendingTitle"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="יש לך חיובים לאישור"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="#1F2937"/>

                            <ImageView
                                android:id="@+id/imgPendingArrow"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_chevron_up"
                                app:tint="#6B7280"/>
                        </LinearLayout>

                    <LinearLayout
                        android:id="@+id/layoutPendingContent"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="8dp"/>

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rvPendingApprovals"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:nestedScrollingEnabled="false"
                            android:overScrollMode="never"/>

                    </LinearLayout>

                </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- ===== EXPENSES BY CATEGORY ===== -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardExpensesByCategory"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@android:color/white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <!-- Header -->
                        <LinearLayout
                            android:id="@+id/headerExpenses"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="הוצאות לפי קטגוריה"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="#111827"/>

                            <ImageView
                                android:id="@+id/imgExpandCategories"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_chevron_up"
                                app:tint="#6B7280"/>
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/layoutExpensesContent"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="12dp"/>

                            <com.google.android.material.button.MaterialButtonToggleGroup
                                android:id="@+id/toggleExpenseType"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:layout_marginTop="8dp"
                                app:singleSelection="true"
                                app:selectionRequired="true"
                                app:checkedButton="@id/btnFixed">

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/btnFixed"
                                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                    android:layout_width="0dp"
                                    android:layout_height="match_parent"
                                    android:layout_weight="1"
                                    android:text="קבועות"/>

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/btnVariable"
                                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                    android:layout_width="0dp"
                                    android:layout_height="match_parent"
                                    android:layout_weight="1"
                                    android:text="משתנות"/>

                            </com.google.android.material.button.MaterialButtonToggleGroup>

                            <androidx.recyclerview.widget.RecyclerView
                                android:id="@+id/rvCategoryExpenses"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:nestedScrollingEnabled="false"
                                android:overScrollMode="never"/>


                            <com.github.mikephil.charting.charts.PieChart
                                android:id="@+id/pieFixedExpenses"
                                android:layout_width="match_parent"
                                android:layout_height="260dp"
                                android:layout_marginTop="16dp"
                                android:layout_marginBottom="16dp" />

                            <com.github.mikephil.charting.charts.BarChart
                                android:id="@+id/barMonthlySummary"
                                android:layout_width="match_parent"
                                android:layout_height="260dp"
                                android:layout_marginTop="16dp" />

                        </LinearLayout>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- ===== SAVINGS GOALS ===== -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardGoals"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#ECFDF5"
                android:layout_marginBottom="96dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Header -->
                    <LinearLayout
                        android:id="@+id/headerGoals"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="🎯 מטרות חיסכון"
                            android:textStyle="bold"
                            android:textSize="16sp"
                            android:textColor="#7F1D1D"/>

                        <ImageView
                            android:id="@+id/imgGoalAlertsArrow"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_chevron_up"
                            app:tint="#7F1D1D"/>
                    </LinearLayout>


                    <View
                        android:layout_width="match_parent"
                        android:layout_height="12dp"/>

                    <!-- Content -->
                    <LinearLayout
                        android:id="@+id/layoutGoalsContent"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rvGoals"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:nestedScrollingEnabled="false"
                            android:overScrollMode="never"
                            />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="12dp"/>

                        <!-- Add Goal Button -->
                        <Button
                            android:id="@+id/btnAddGoal"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:text="➕ הוסף מטרה חדשה"
                            android:textAllCaps="false"
                            android:textColor="#065F46"
                            android:backgroundTint="#D1FAE5" />
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </androidx.coordinatorlayout.widget.CoordinatorLayout>




    <!-- ===== FLOATING ACTION BUTTON ===== -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btnAddTransaction"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="24dp"
        android:src="@drawable/ic_plus"
        app:tint="@android:color/white"
        app:backgroundTint="@color/indigo_600" />

    <eightbitlab.com.blurview.BlurView
        android:id="@+id/lockOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:src="@drawable/ic_lock_white"
                app:tint="@android:color/white"/>

            <TextView
                android:text="עמוד זה נעול"
                android:layout_height="wrap_content"
                android:layout_width="wrap_content"
                android:textColor="@android:color/white"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp"/>

        </LinearLayout>

    </eightbitlab.com.blurview.BlurView>
</FrameLayout>