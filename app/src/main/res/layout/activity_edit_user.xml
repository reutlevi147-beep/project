<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layoutDirection="rtl"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ===== HEADER ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:orientation="vertical"
            android:gravity="center_vertical"
            android:padding="24dp"
            android:background="#64748B">

            <TextView
                android:text="עריכת פרופיל"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="עדכון פרטים אישיים"
                android:textColor="#E5E7EB"
                android:layout_marginTop="8dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- ===== AVATAR ===== -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="-48dp"
            android:layout_marginBottom="16dp"
            android:gravity="center">

            <FrameLayout
                android:layout_width="120dp"
                android:layout_height="120dp">

                <ImageView
                    android:id="@+id/imgAvatar"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:background="@drawable/bg_circle_avatar"
                    android:src="@drawable/ic_user"
                    android:scaleType="centerCrop"
                    android:padding="0dp"
                    app:tint="@null" />


            </FrameLayout>
        </FrameLayout>

        <!-- ===== CONTENT ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <EditText
                android:id="@+id/etName"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="שם"
                android:background="@drawable/bg_input_rounded"
                android:padding="16dp"
                android:layout_marginBottom="16dp"/>

            <EditText
                android:id="@+id/etPhone"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="טלפון"
                android:inputType="phone"
                android:background="@drawable/bg_input_rounded"
                android:padding="16dp"
                android:layout_marginBottom="16dp"/>

            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="אימייל"
                android:inputType="textEmailAddress"
                android:background="@drawable/bg_input_rounded"
                android:padding="16dp"
                android:layout_marginBottom="16dp"/>

            <!-- תפקיד (הורה / ילד) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="תפקיד במשפחה"
                android:textStyle="bold"
                android:textColor="#111827"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"/>

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/toggleRole"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                app:selectionRequired="true">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnParent"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="הורה"
                    app:cornerRadius="12dp"
                    app:backgroundTint="@color/role_toggle_bg"
                    app:strokeColor="@color/teal_600"
                    app:strokeWidth="1dp"
                    android:textColor="@color/role_toggle_text"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnChild"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="ילד"
                    app:cornerRadius="12dp"
                    app:backgroundTint="@color/role_toggle_bg"
                    app:strokeColor="@color/teal_600"
                    app:strokeWidth="1dp"
                    android:textColor="@color/role_toggle_text"/>

            </com.google.android.material.button.MaterialButtonToggleGroup>


            <Button
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="שמור שינויים"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:background="#475569"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
