<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layoutDirection="rtl"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ===== HEADER ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:orientation="vertical"
            android:gravity="center_vertical"
            android:padding="24dp"
            android:background="#64748B">

            <TextView
                android:text="עריכת פרופיל"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="עדכון פרטים אישיים"
                android:textColor="#E5E7EB"
                android:layout_marginTop="8dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- ===== AVATAR ===== -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="-48dp"
            android:layout_marginBottom="16dp"
            android:gravity="center">

            <FrameLayout
                android:layout_width="120dp"
                android:layout_height="120dp">

                <ImageView
                    android:id="@+id/imgAvatar"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:background="@drawable/bg_circle_avatar"
                    android:src="@drawable/ic_user"
                    android:scaleType="centerCrop"
                    android:padding="0dp"
                    android:tint="@null" />


            </FrameLayout>
        </FrameLayout>

        <!-- ===== CONTENT ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <EditText
                android:id="@+id/etName"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="שם"
                android:background="@drawable/bg_input_rounded"
                android:padding="16dp"
                android:layout_marginBottom="16dp"/>

            <EditText
                android:id="@+id/etPhone"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="טלפון"
                android:inputType="phone"
                android:background="@drawable/bg_input_rounded"
                android:padding="16dp"
                android:layout_marginBottom="16dp"/>

            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="אימייל"
                android:inputType="textEmailAddress"
                android:background="@drawable/bg_input_rounded"
                android:padding="16dp"
                android:layout_marginBottom="16dp"/>

            <EditText
                android:id="@+id/etRole"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="תפקיד במשפחה"
                android:background="@drawable/bg_input_rounded"
                android:padding="16dp"
                android:layout_marginBottom="24dp"/>

            <Button
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="שמור שינויים"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:background="#475569"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
