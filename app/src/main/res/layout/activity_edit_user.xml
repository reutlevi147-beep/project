<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F6F8"
    android:layoutDirection="rtl">

    <!-- ================= CONTENT ================= -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- ===== HEADER ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="217dp"
            android:background="#5C5F66"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="עריכת פרופיל"
                android:textColor="@android:color/white"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="עדכון פרטים אישיים"
                android:textColor="#DADADA"
                android:textSize="14sp" />

        </LinearLayout>

        <!-- ===== CARD AREA ===== -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="70dp"
                app:cardBackgroundColor="#F0F0F3"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="6dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <!-- Name -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="שם מלא">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Phone -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:hint="טלפון">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etPhone"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Email -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:hint="אימייל">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etEmail"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Role -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="תפקיד במשפחה"
                        android:textStyle="bold"
                        android:textColor="#444444"
                        android:layout_marginTop="24dp"/>

                    <LinearLayout
                        android:id="@+id/layoutRoleSelector"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="horizontal">

                        <!-- ===== CHILD ===== -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardChild"
                            android:layout_width="0dp"
                            android:layout_height="60dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            app:cardCornerRadius="30dp"
                            app:strokeWidth="2dp"
                            app:strokeColor="#BDBDBD"
                            app:cardBackgroundColor="@android:color/white">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:orientation="horizontal">

                                <ImageView
                                    android:id="@+id/iconChildCheck"
                                    android:layout_width="18dp"
                                    android:layout_height="18dp"
                                    android:layout_marginStart="6dp"
                                    android:visibility="gone"
                                    android:src="@drawable/ic_check_20"/>

                                <TextView
                                    android:id="@+id/tvChild"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="ילד"
                                    android:textStyle="bold"
                                    android:textSize="14sp"/>
                            </LinearLayout>

                        </com.google.android.material.card.MaterialCardView>

                        <!-- ===== PARENT ===== -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardParent"
                            android:layout_width="0dp"
                            android:layout_height="60dp"
                            android:layout_weight="1"
                            app:cardCornerRadius="30dp"
                            app:strokeWidth="2dp"
                            app:strokeColor="#BDBDBD"
                            app:cardBackgroundColor="@android:color/white">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:orientation="horizontal">

                                <ImageView
                                    android:id="@+id/iconParentCheck"
                                    android:layout_width="18dp"
                                    android:layout_height="18dp"
                                    android:layout_marginStart="6dp"
                                    android:visibility="gone"
                                    android:src="@drawable/ic_check_20"/>

                                <TextView
                                    android:id="@+id/tvParent"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="הורה"
                                    android:textStyle="bold"
                                    android:textSize="14sp"/>
                            </LinearLayout>

                        </com.google.android.material.card.MaterialCardView>

                    </LinearLayout>



                    <!-- Save Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSave"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="28dp"
                        android:text="שמור שינויים"
                        android:textStyle="bold"
                        app:cornerRadius="18dp"
                        android:backgroundTint="#424242"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </FrameLayout>

    </LinearLayout>

    <!-- ================= FLOATING AVATAR ================= -->
    <ImageView
        android:id="@+id/imgProfile"
        android:layout_width="110dp"
        android:layout_height="110dp"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="165dp"
        android:scaleType="centerCrop"
        android:background="@drawable/bg_dot_gray"
        android:elevation="12dp"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
