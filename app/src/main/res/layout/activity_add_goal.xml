<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F9FAFB"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ===== HEADER ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp"
            android:background="@drawable/bg_gradient_green"
            android:orientation="vertical">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_arrow_right"
                app:tint="@android:color/white"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="מטרה חדשה"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:layout_marginTop="12dp"/>
        </LinearLayout>

        <!-- ===== PREVIEW CARD ===== -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardGoalPreview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#ECFDF5">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- כותרת עליונה -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <ImageView
                        android:id="@+id/imgGoalPreviewIcon"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_circle_light"
                        android:padding="10dp"
                        android:src="@drawable/ic_target"
                        app:tint="#059669"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="מטרה חדשה"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#065F46"
                        android:layout_marginStart="12dp"/>
                </LinearLayout>

                <!-- ===== שם מטרה ===== -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="שם המטרה *"
                    android:textSize="14sp"
                    android:textColor="#111827"/>

                <EditText
                    android:id="@+id/etGoalTitle"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_input_rounded"
                    android:hint="למשל: טיול לאיטליה"
                    android:padding="14dp"
                    android:maxLength="30"
                    android:inputType="text"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0/30"
                    android:textSize="12sp"
                    android:textColor="#9CA3AF"
                    android:layout_marginTop="4dp"/>

                <!-- ===== סכום יעד ===== -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="סכום יעד *"
                    android:textSize="14sp"
                    android:textColor="#111827"
                    android:layout_marginTop="16dp"/>

                <EditText
                    android:id="@+id/etTargetAmount"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_input_rounded"
                    android:hint="0 ₪"
                    android:padding="14dp"
                    android:inputType="number"/>

                <!-- ===== סכום קיים ===== -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="סכום קיים (אופציונלי)"
                    android:textSize="14sp"
                    android:textColor="#111827"
                    android:layout_marginTop="16dp"/>

                <EditText
                    android:id="@+id/etCurrentAmount"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_input_rounded"
                    android:hint="0 ₪"
                    android:padding="14dp"
                    android:inputType="number"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="אם כבר יש לך כסף חסוך למטרה זו"
                    android:textSize="12sp"
                    android:textColor="#6B7280"
                    android:layout_marginTop="4dp"/>

                <!-- ===== תאריך יעד ===== -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="תאריך יעד (אופציונלי)"
                    android:textSize="14sp"
                    android:textColor="#111827"
                    android:layout_marginTop="16dp"/>

                <EditText
                    android:id="@+id/etDeadline"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_input_rounded"
                    android:hint="למשל: דצמבר 2026"
                    android:padding="14dp"
                    android:inputType="text"/>

                <!-- ===== סוג מטרה ===== -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="סוג המטרה"
                    android:textSize="14sp"
                    android:textColor="#111827"
                    android:layout_marginTop="20dp"/>

                <RadioGroup
                    android:id="@+id/rgGoalType"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">

                    <RadioButton
                        android:id="@+id/rbYearly"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:checked="true"
                        android:text="שנתי"
                        android:gravity="center"
                        android:button="@null"
                        android:background="@drawable/bg_goal_type_selected"
                        android:textColor="#065F46"/>

                    <Space
                        android:layout_width="12dp"
                        android:layout_height="1dp"/>

                    <RadioButton
                        android:id="@+id/rbMonthly"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:text="חודשי"
                        android:gravity="center"
                        android:button="@null"
                        android:background="@drawable/bg_goal_type_unselected"
                        android:textColor="#374151"/>
                </RadioGroup>
                <!-- סוג מטרה -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="סוג מטרה"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="#111827"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="20dp">

                    <!-- SAVE -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardGoalSave"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#ECFDF5">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp"
                            android:gravity="center">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="💰"
                                android:textSize="28sp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="חיסכון / הכנסה"
                                android:textStyle="bold"
                                android:textSize="14sp"
                                android:textColor="#065F46"
                                android:layout_marginTop="6dp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="להכניס כסף"
                                android:textSize="12sp"
                                android:textColor="#047857"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- LIMIT -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardGoalLimit"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#EFF6FF">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp"
                            android:gravity="center">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="💳"
                                android:textSize="28sp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="תקציב / הוצאה"
                                android:textStyle="bold"
                                android:textSize="14sp"
                                android:textColor="#1E3A8A"
                                android:layout_marginTop="6dp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="לא לעבור סכום"
                                android:textSize="12sp"
                                android:textColor="#2563EB"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                </LinearLayout>
                <!-- ===== שמור ===== -->
                <Button
                    android:id="@+id/btnSaveGoal"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="28dp"
                    android:text="שמור מטרה"
                    android:textAllCaps="false"
                    android:textSize="16sp"
                    android:textColor="@android:color/white"
                    android:backgroundTint="#10B981"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
