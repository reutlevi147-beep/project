<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="6dp"
    app:cardBackgroundColor="#F3EDF9">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- שורה עליונה: שם + תפקיד + אוואטר -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- טקסטים -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="שרה"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#212121" />

                <TextView
                    android:id="@+id/tvRole"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="הורה • משפחת כהן"
                    android:textSize="14sp"
                    android:textColor="#757575" />
            </LinearLayout>

            <!-- אוואטר -->
            <FrameLayout
                android:layout_width="64dp"
                android:layout_height="64dp">

                <ImageView
                    android:id="@+id/imgAvatar"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_user"
                    android:padding="6dp"
                    android:background="@drawable/bg_circle_avatar"/>


            </FrameLayout>
        </LinearLayout>

        <!-- קו הפרדה -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="12dp"
            android:background="#E0E0E0" />

        <!-- פרטי קשר -->
        <TextView
            android:id="@+id/tvPhone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="050-1234567"
            android:textSize="14sp"
            android:textColor="#424242" />

        <TextView
            android:id="@+id/tvEmail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="sarah@example.com"
            android:textSize="14sp"
            android:textColor="#424242"
            android:layout_marginBottom="12dp" />

        <!-- כפתור עריכה (בעתיד – רק למשתמש עצמו) -->
        <Button
            android:id="@+id/btnEditProfile"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="ערוך פרופיל"
            android:textColor="#3F51B5"
            android:backgroundTint="#E8EAF6" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
