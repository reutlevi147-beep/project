<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="6dp"
    app:cardBackgroundColor="@android:color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ===== שורה עליונה ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- טקסטים (משקל 1 כדי שהאוואטר יהיה בצד ימין) -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <!-- שם + כתר -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tvName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="שרה"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#212121" />

                    <TextView
                        android:id="@+id/tvParentBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" 👑"
                        android:textSize="14sp"
                        android:textColor="#F59E0B"
                        android:visibility="gone"
                        android:layout_marginStart="6dp"/>
                </LinearLayout>

                <!-- תפקיד -->
                <TextView
                    android:id="@+id/tvRole"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="הורה"
                    android:textSize="14sp"
                    android:textColor="#757575"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <!-- אוואטר -->
            <FrameLayout
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_marginStart="12dp">

                <ImageView
                    android:id="@+id/imgAvatar"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_user"
                    android:scaleType="centerCrop"
                    android:background="@drawable/bg_circle_avatar"/>
            </FrameLayout>

        </LinearLayout>

        <!-- ===== קו הפרדה (נשלט מה-Adapter) ===== -->
        <View
            android:id="@+id/viewDivider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="12dp"
            android:background="#E0E0E0"
            android:visibility="gone" />

        <!-- ===== פרטי קשר ===== -->
        <TextView
            android:id="@+id/tvPhone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="050-1234567"
            android:textSize="14sp"
            android:textColor="#424242" />

        <TextView
            android:id="@+id/tvEmail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="sarah@example.com"
            android:textSize="14sp"
            android:textColor="#424242"
            android:layout_marginBottom="12dp" />

        <!-- ===== כפתור עריכה ===== -->
        <Button
            android:id="@+id/btnEditProfile"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="ערוך פרופיל"
            android:textColor="@android:color/white"
            android:backgroundTint="#5C5F66" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>