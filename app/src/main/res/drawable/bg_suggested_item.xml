<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- צבע רקע עדין -->
    <solid android:color="#ECFEFF" />

    <!-- פינות מעוגלות -->
    <corners android:radius="14dp" />

    <!-- מסגרת דקה -->
    <stroke
        android:width="1dp"
        android:color="#5EEAD4" />

    <!-- ריווח פנימי -->
    <padding
        android:left="8dp"
        android:top="6dp"
        android:right="8dp"
        android:bottom="6dp" />

</shape>
