    <item android:id="@android:id/background">
        <shape>
            <corners android:radius="6dp"/>
            <solid android:color="#E5E7EB"/>
        </shape>
    </item>

    <item android:id="@android:id/progress">
        <clip>
            <shape>
                <corners android:radius="6dp"/>
                <solid android:color="#9CA3AF"/> <!-- אפור -->
            </shape>
        </clip>
    </item>

</layer-list>
