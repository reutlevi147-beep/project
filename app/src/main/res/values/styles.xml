<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Label מעל שדות -->
    <style name="LabelStyle">
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">#374151</item>
        <item name="android:layout_marginBottom">6dp</item>
    </style>

    <!-- שדות קלט -->
    <style name="InputStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@drawable/bg_input</item>
        <item name="android:padding">16dp</item>
        <item name="android:layout_marginBottom">16dp</item>
    </style>

    <!-- כרטיסי רדיו (סוג קבוצה) -->
    <style name="RadioCardStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@drawable/bg_radio_card</item>
        <item name="android:padding">16dp</item>
        <item name="android:layout_marginBottom">12dp</item>
    </style>


    <style name="RoleCardStyle">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:background">@drawable/bg_radio_card</item>
        <item name="android:padding">16dp</item>
    </style>

    <!-- Summary Box (יומן - סיכום יום) -->
    <style name="SummaryBox">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>

        <item name="android:padding">16dp</item>
        <item name="android:layout_margin">4dp</item>

        <item name="android:background">@drawable/bg_card</item>
    </style>

    <style name="CategoryButton">
        <item name="android:background">@drawable/bg_category</item>
        <item name="android:textColor">#444</item>
        <item name="android:textSize">14sp</item>
        <item name="android:paddingHorizontal">16dp</item>
        <item name="android:paddingVertical">8dp</item>
    </style>

    <style name="CategoryButtonSelected">
        <item name="android:background">@drawable/bg_category_selected</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textStyle">bold</item>
    </style>




</resources>
